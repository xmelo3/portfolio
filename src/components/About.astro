---
import { Image } from 'astro:assets';
import profilePhoto from '../assets/profile_photo.jpg';
---
<section id="omne" class="about">
  <div class="about-inner">
    <div class="about-text">
      <h2 class="section-title">
        Tvorím <em>priestory</em>, hľadám mierku.
      </h2>
      <p>Som študentka architektúry.</p>
      <p class="muted">
        Toto portfólio zahŕňa výber školských projektov z dvoch semestrov.
      </p>
      <dl class="about-facts">
        <dt>Štúdium</dt><dd>VŠB TUO · 2025 - dnes</dd>
        <dt>Lokalita</dt><dd>Ostrava · CZ</dd>
        <dt>Software</dt><dd>AutoCAD · Rhino · Adobe</dd>
      </dl>
    </div>

    <div class="about-portrait tile dark">
      <Image
        src={profilePhoto}
        alt="Profile photo"
        width={600}
        height={800}
        class="portrait-img"
      />
    </div>
  </div>
</section>