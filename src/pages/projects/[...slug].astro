---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const pad = (n: number) => String(n).padStart(2, '0');

const drawings = [
  { label: 'Rez',        img: project.data.rez },
  { label: 'Axonometria',img: project.data.axonometria },
  { label: 'Pôdorys',    img: project.data.pôdorys },
  { label: 'Plagát',     img: project.data.plagát },
].filter((d): d is { label: string; img: NonNullable<typeof d.img> } => d.img != null);
---

<Base title={`${project.data.title} — portfolio`}>
  <Header />

  <main class="project-detail">
    <div class="project-inner">
      <a href="/#projekty" class="back-link">← Späť na projekty</a>

      <header class="project-header">
        <span class="eyebrow">Projekt {pad(project.data.order)}</span>
        <h1 class="project-title">{project.data.title}</h1>
      </header>

      <div class="project-body">
        <Content />
      </div>

      {drawings.length > 0 && (
        <div class="project-gallery" id="lightbox-gallery">
          {drawings.map((drawing, i) => (
            <a
              href={drawing.img.src}
              data-pswp-width={drawing.img.width}
              data-pswp-height={drawing.img.height}
              data-label={drawing.label}
              class="gallery-item"
              target="_blank"
              rel="noreferrer"
            >
              <Image
                src={drawing.img}
                alt={`${project.data.title} — ${drawing.label}`}
                width={800}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
                class="gallery-thumb"
              />
            </a>
          ))}
        </div>
      )}
    </div>
  </main>

  <Footer />
</Base>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#lightbox-gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
  });
  lightbox.init();
</script>