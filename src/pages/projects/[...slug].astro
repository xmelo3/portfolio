---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  console.log('STATIC PATHS — projects found:', projects.length);
  console.log('IDs:', projects.map(p => p.id));
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const pad = (n: number) => String(n).padStart(2, '0');
---
<Base title={`${project.data.title} — portfolio`}>
  <Header />

  <main class="project-detail">
    <div class="project-inner">
      <a href="/#projekty" class="back-link">← Späť na projekty</a>

      <header class="project-header">
        <span class="eyebrow">Projekt {pad(project.data.order)}</span>
        <h1 class="project-title">{project.data.title}</h1>
      </header>
      
      <div class="project-body">
        <Content />
      </div>

      {project.data.gallery.length > 0 && (
        <div class="project-gallery" id="lightbox-gallery">
          {project.data.gallery.map(async (img, i) => {
            const { getImage } = await import('astro:assets');
            const thumb = await getImage({ src: img, width: 800 });
            const full = await getImage({ src: img, width: 2000 });
            return (
              <a
                href={full.src}
                data-pswp-width={full.attributes.width || 2000}
                data-pswp-height={full.attributes.height || 1500}
                class="gallery-item"
                target="_blank"
                rel="noreferrer"
              >
                <img
                  src={thumb.src}
                  alt={`${project.data.title} — ${i + 1}`}
                  loading="lazy"
                />
              </a>
            );
          })}
        </div>
      )}
    </div>
  </main>

  <Footer />
</Base>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#lightbox-gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
  });
  lightbox.init();
</script>
